# Copy to .env and fill in real values. .env is gitignored — never commit it.

# --- TMDB API ---
# Get a key at https://www.themoviedb.org/settings/api (v3 auth)
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3

# --- AWS / S3 Data Lake ---
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=eu-central-1
S3_BUCKET=your-bucket

# --- PostgreSQL Warehouse ---
# Format: postgresql+psycopg2://user:password@host:port/dbname
DATABASE_URL=postgresql+psycopg2://theoria:theoria@localhost:5432/theoria

# --- Ingestion tuning ---
MAX_PAGES=5

# --- Django ---
DJANGO_SECRET_KEY=change_me_in_production
DJANGO_DEBUG=True
